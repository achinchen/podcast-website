---
import Base from '../layouts/Base.astro';
import EpisodeCard from '../components/EpisodeCard.astro';
import PlatformBadges from '../components/PlatformBadges.astro';
import { getEpisodes } from '../utils/rss.js';
import { SITE } from '../config.js';
const episodes = await getEpisodes();
const latest = episodes.slice(0, 3);
---
<Base image={episodes[0]?.cover}>
  <section class="py-24 text-center sm:py-32">
    <h1 class="font-display text-6xl font-bold text-brand-ink sm:text-7xl">{SITE.name}</h1>
    <p class="mx-auto mt-6 max-w-xl text-xl text-muted-fg sm:whitespace-break-spaces">{SITE.tagline}</p>
    <div class="mt-10 flex justify-center gap-4"><PlatformBadges /></div>
  </section>
  <section class="mt-16">
    <h2 class="font-display text-3xl font-bold text-brand-ink sm:text-4xl">最新</h2>
    <div class="mt-8 divide-y divide-border">
      {latest.map((ep) => <EpisodeCard episode={ep} />)}
    </div>
    <p class="mt-12 text-center">
      <a href="/episodes" class="badge-pill">
        看全部 →
      </a>
    </p>
  </section>
</Base>
