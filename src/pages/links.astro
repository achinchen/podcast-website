---
import Base from '../layouts/Base.astro';
import { getFeedMeta } from '../utils/rss.js';
import { SITE } from '../config.js';
import ApplePodcasts from '../components/icons/ApplePodcasts.astro';
import Spotify from '../components/icons/Spotify.astro';
import SoundOn from '../components/icons/SoundOn.astro';
import KKBOX from '../components/icons/KKBOX.astro';
import Instagram from '../components/icons/Instagram.astro';

const meta = await getFeedMeta();
const soundonUrl = SITE.soundon || meta.link;
const cover = meta.cover;
---
<Base title={`${SITE.name} | Links`} description={SITE.tagline} image={cover}>
  <div class="mx-auto max-w-sm py-12 text-center">
    {cover && (
      <img
        src={cover}
        alt={`${SITE.name} 封面`}
        width="128"
        height="128"
        class="mx-auto w-32 rounded-2xl"
      />
    )}
    <h1 class="mt-6 font-display text-3xl font-bold text-brand-blue">{SITE.name}</h1>
    <p class="mt-2 text-brand-ink">{SITE.tagline}</p>
    <nav class="mt-8 flex flex-col gap-4">
      <a
        href={SITE.applePodcasts}
        class="badge-pill w-full justify-center text-center"
        target="_blank"
        rel="noopener"
      >
        <ApplePodcasts class="mr-2 inline-block h-5 w-5" />
        在 Apple Podcasts 收聽
      </a>
      <a
        href={SITE.spotify}
        class="badge-pill w-full justify-center text-center"
        target="_blank"
        rel="noopener"
      >
        <Spotify class="mr-2 inline-block h-5 w-5" />
        在 Spotify 收聽
      </a>
      <a
        href={soundonUrl}
        class="badge-pill w-full justify-center text-center"
        target="_blank"
        rel="noopener"
      >
        <SoundOn class="mr-2 inline-block h-5 w-5" />
        在 SoundOn 收聽
      </a>
      <a
        href={SITE.kkbox}
        class="badge-pill w-full justify-center text-center"
        target="_blank"
        rel="noopener"
      >
        <KKBOX class="mr-2 inline-block h-5 w-5" />
        在 KKBOX 收聽
      </a>
      <a
        href={SITE.instagram}
        class="badge-pill w-full justify-center text-center"
        target="_blank"
        rel="noopener"
      >
        <Instagram class="mr-2 inline-block h-5 w-5" />
        追蹤 Instagram
      </a>
    </nav>
  </div>
</Base>
