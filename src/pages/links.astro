---
import Base from '../layouts/Base.astro';
import { getFeedMeta } from '../utils/rss.js';
import { SITE } from '../config.js';
import Home from '../components/icons/Home.astro';
import appleLogo from '../assets/apple-podcast/logo.png';
import spotifyLogo from '../assets/spotify/logo.png';
import kkboxLogo from '../assets/kkbox/logo.png';
import youtubeMusicLogo from '../assets/youtube-music/logo.png';
import soundonLogo from '../assets/soundon/logo.png'; 

const meta = await getFeedMeta();
const cover = meta.cover;
---
<Base title={`${SITE.name} | Links`} description={SITE.tagline} image={cover} chrome={false}>
  <div class="mx-auto max-w-md px-10 pb-8">
    {cover && (
      <img
        src={cover}
        alt={`${SITE.name} 封面`}
        width="240"
        height="240"
        class="mx-auto w-92 rounded-2xl"
      />
    )}
    <p class="translate-y--4 text-sm text-center text-muted-fg">🥑：從今以後我也是 podcaster 了嗎？ 😂</p>
    <nav class="mt-8 flex flex-col gap-2">
      <a href={SITE.spotify} class="flex items-center gap-4 border py-4 px-4 rounded-2xl transition-colors duration-200 hover:text-brand-blue focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2" target="_blank" rel="noopener">
        <img src={spotifyLogo.src} alt="" class="h-6 w-6 shrink-0 rounded-full" />
        <span class="font-medium">在 Spotify 收聽</span>
      </a>
      <a href={SITE.applePodcasts} class="flex items-center gap-4 border py-4 px-4 rounded-2xl transition-colors duration-200 hover:text-brand-blue focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2" target="_blank" rel="noopener">
        <img src={appleLogo.src} alt="" class="h-6 w-6 shrink-0 rounded" />
        <span class="font-medium">在 Apple Podcasts 收聽</span>
      </a>
      <a href={SITE.youtubeMusic} class="flex items-center gap-4 border py-4 px-4 rounded-2xl transition-colors duration-200 hover:text-brand-blue focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2" target="_blank" rel="noopener">
        <img src={youtubeMusicLogo.src} alt="" class="h-6 w-6 shrink-0" />
        <span class="font-medium">在 YouTube Music 收聽</span>
      </a>
      <a href={SITE.kkbox} class="flex items-center gap-4 border py-4 px-4 rounded-2xl transition-colors duration-200 hover:text-brand-blue focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2" target="_blank" rel="noopener">
        <img src={kkboxLogo.src} alt="" class="h-6 w-6 shrink-0 rounded" />
        <span class="font-medium">在 KKBOX 收聽</span>
      </a>
      <a href={SITE.soundon} class="flex items-center gap-4 border py-4 px-4 rounded-2xl transition-colors duration-200 hover:text-brand-blue focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2" target="_blank" rel="noopener">
        <img src={soundonLogo.src} alt="" class="h-6 w-6 shrink-0" />
        <span class="font-medium">在 SoundOn 收聽</span>
      </a>
      <a href="/" class="flex items-center gap-4 border py-4 px-4 rounded-2xl transition-colors duration-200 hover:text-brand-blue focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2" target="_blank" rel="noopener">
        <Home class="h-6 w-6 shrink-0 text-brand-blue" />
        <span class="font-medium">Podcast 的家</span>
      </a>
    </nav>
  </div>
</Base>
