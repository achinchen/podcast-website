---
import Base from '../layouts/Base.astro';
import { getFeedMeta } from '../utils/rss.js';
import { SITE } from '../config.js';
import ApplePodcasts from '../components/icons/ApplePodcasts.astro';
import Spotify from '../components/icons/Spotify.astro';
import SoundOn from '../components/icons/SoundOn.astro';

const meta = await getFeedMeta();
const soundonUrl = SITE.soundon || meta.link;
const cover = meta.cover;
---
<Base title={`${SITE.name} | Links`} description={SITE.tagline} image={cover} chrome={false}>
  <div class="mx-auto max-w-md py-16">
    {cover && (
      <img
        src={cover}
        alt={`${SITE.name} 封面`}
        width="128"
        height="128"
        class="mx-auto w-32 rounded-2xl"
      />
    )}
    <p class="mt-3 text-center text-lg text-muted-fg">{SITE.tagline}</p>
    <nav class="mt-12 divide-y divide-border">
      <a href={SITE.applePodcasts} class="flex items-center gap-4 py-5 transition-colors duration-200 hover:text-brand-blue focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2" target="_blank" rel="noopener">
        <ApplePodcasts class="h-6 w-6 shrink-0" />
        <span class="font-medium">在 Apple Podcasts 收聽</span>
      </a>
      <a href={SITE.spotify} class="flex items-center gap-4 py-5 transition-colors duration-200 hover:text-brand-blue focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2" target="_blank" rel="noopener">
        <Spotify class="h-6 w-6 shrink-0" />
        <span class="font-medium">在 Spotify 收聽</span>
      </a>
      <a href={soundonUrl} class="flex items-center gap-4 py-5 transition-colors duration-200 hover:text-brand-blue focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2" target="_blank" rel="noopener">
        <SoundOn class="h-6 w-6 shrink-0" />
        <span class="font-medium">在 SoundOn 收聽</span>
      </a>
    </nav>
  </div>
</Base>
