---
import Base from '../layouts/Base.astro';
import { getFeedMeta } from '../utils/rss.js';
import { SITE } from '../config.js';
import ApplePodcasts from '../components/icons/ApplePodcasts.astro';
import Spotify from '../components/icons/Spotify.astro';
import SoundOn from '../components/icons/SoundOn.astro';

const meta = await getFeedMeta();
const soundonUrl = SITE.soundon || meta.link;
const cover = meta.cover;
---
<Base title={`${SITE.name} | Links`} description={SITE.tagline} image={cover}>
  <div class="mx-auto max-w-sm py-12 text-center">
    {cover && (
      <img
        src={cover}
        alt={`${SITE.name} 封面`}
        width="128"
        height="128"
        class="mx-auto w-32 rounded-2xl"
      />
    )}
    <h1 class="mt-6 font-display text-3xl font-bold text-brand-blue">{SITE.name}</h1>
    <p class="mt-2 text-muted-fg">{SITE.tagline}</p>
    <nav class="mt-8 flex flex-col gap-4">
      <a href={SITE.applePodcasts} class="card card-hover flex items-center justify-center gap-3 py-4" target="_blank" rel="noopener">
        <ApplePodcasts class="h-6 w-6" />
        <span class="font-medium">在 Apple Podcasts 收聽</span>
      </a>
      <a href={SITE.spotify} class="card card-hover flex items-center justify-center gap-3 py-4" target="_blank" rel="noopener">
        <Spotify class="h-6 w-6" />
        <span class="font-medium">在 Spotify 收聽</span>
      </a>
      <a href={soundonUrl} class="card card-hover flex items-center justify-center gap-3 py-4" target="_blank" rel="noopener">
        <SoundOn class="h-6 w-6" />
        <span class="font-medium">在 SoundOn 收聽</span>
      </a>
    </nav>
  </div>
</Base>
