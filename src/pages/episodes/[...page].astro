---
import Base from '../../layouts/Base.astro';
import EpisodeCard from '../../components/EpisodeCard.astro';
import { getEpisodes } from '../../utils/rss.js';
import { SITE } from '../../config.js';

export async function getStaticPaths({ paginate }) {
  const episodes = await getEpisodes();
  return paginate(episodes, { pageSize: 10 });
}
const { page } = Astro.props;
---
<Base title={`全部（第 ${page.currentPage} 頁）｜${SITE.name}`}>
  <h1 class="mt-8 font-display text-3xl font-bold text-brand-blue sm:text-4xl">全部</h1>
  <div class="mt-8 grid gap-6 sm:grid-cols-2">
    {page.data.map((ep) => <EpisodeCard episode={ep} />)}
  </div>
  <nav class="mt-10 flex items-center justify-between" aria-label="分頁">
    {page.url.prev
      ? <a href={page.url.prev} class="badge-pill">← 較新</a>
      : <span class="badge-pill pointer-events-none opacity-40" aria-disabled="true">← 較新</span>}
    <span class="text-sm font-medium text-muted-fg">第 {page.currentPage} / {page.lastPage} 頁</span>
    {page.url.next
      ? <a href={page.url.next} class="badge-pill">較舊 →</a>
      : <span class="badge-pill pointer-events-none opacity-40" aria-disabled="true">較舊 →</span>}
  </nav>
</Base>
