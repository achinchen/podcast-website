---
import { SITE } from '../config.js';
import { getFeedMeta } from '../utils/rss.js';
import appleLogo from '../assets/apple-podcast/logo.png';
import spotifyLogo from '../assets/spotify/logo.png';
import kkboxLogo from '../assets/kkbox/logo.png';
import youtubeMusicLogo from '../assets/youtube-music/logo.png';
import soundonLogo from '../assets/soundon/logo.png';

const meta = await getFeedMeta();

const platforms = [
  { label: '在 Apple Podcasts 收聽', href: SITE.applePodcasts, logo: appleLogo, id: 'apple-podcasts' },
  { label: '在 Spotify 收聽', href: SITE.spotify, logo: spotifyLogo, id: 'spotify' },
  { label: '在 KKBOX 收聽', href: SITE.kkbox, logo: kkboxLogo, id: 'kkbox' },
  { label: '在 YouTube Music 收聽', href: SITE.youtubeMusic || meta.link, logo: youtubeMusicLogo, id: 'youtube-music' },
  { label: '在 SoundOn 收聽', href: SITE.soundon, logo: soundonLogo, id: 'soundon' },
];

const roundedIcons = ['spotify', 'youtube-music', 'soundon'];
---
<div class="flex flex-wrap gap-4">
  {platforms.map((p) => (
    <a
      href={p.href}
      target="_blank"
      rel="noopener"
      aria-label={p.label}
      class={`flex h-11 w-11 items-center justify-center ${roundedIcons.includes(p.id) ? 'rounded-full' : 'rounded-xl'}  transition-colors duration-200 hover:bg-brand-blue-tint focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring`}
    >
      <img src={p.logo.src} alt="" class="h-10 w-10" />
    </a>
  ))}
</div>
