---
import { SITE } from '../config.js';
import appleLogo from '../assets/apple-podcast/logo.png';
import spotifyLogo from '../assets/spotify/logo.png';

const platforms = [
  { label: '在 Apple Podcasts 收聽', href: SITE.applePodcasts, logo: appleLogo, id: 'apple-podcasts' },
  { label: '在 Spotify 收聽', href: SITE.spotify, logo: spotifyLogo, id: 'spotify' },
];
---
<div class="flex flex-wrap gap-4">
  {platforms.map((p) => (
    <a
      href={p.href}
      target="_blank"
      rel="noopener"
      aria-label={p.label}
      class={`flex h-11 w-11 items-center justify-center ${p.id === 'apple-podcasts' ? 'rounded-xl' : 'rounded-full'}  transition-colors duration-200 hover:bg-brand-blue-tint focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring`}
    >
      <img src={p.logo.src} alt="" class="h-10 w-10" />
    </a>
  ))}
</div>
