---
import { SITE } from '../config.js';
import appleLogo from '../assets/apple-podcast/logo.png';
import spotifyLogo from '../assets/spotify/logo.png';

const platforms = [
  { label: '在 Apple Podcasts 收聽', href: SITE.applePodcasts, logo: appleLogo },
  { label: '在 Spotify 收聽', href: SITE.spotify, logo: spotifyLogo },
];
---
<div class="flex flex-wrap gap-3">
  {platforms.map((p) => (
    <a
      class="badge-pill inline-flex items-center gap-2"
      href={p.href}
      target="_blank"
      rel="noopener"
    >
      <img src={p.logo.src} alt="" class="h-5 w-5" />
      {p.label}
    </a>
  ))}
</div>
